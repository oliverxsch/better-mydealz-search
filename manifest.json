{
  "manifest_version": 3,
  "name": "Better Mydealz Search",
  "version": "1.0.0",
  "description": "Ersetzt die native Mydealz-Suche durch eine strukturierte Google Site-Search (mit Zeitfilter & ohne abgelaufene Deals).",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage"
  ],
  "host_permissions": [
    "*://*.mydealz.de/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sucheinstellungen"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "better-mydealz-search@oliverxsch.github.io"
    }
  },
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png"
  }
}
